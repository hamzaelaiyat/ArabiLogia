# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# OneSignal (push notifications)
ONESIGNAL_API_KEY=your-onesignal-api-key

# Google AI (optional - for AI release notes)
# Get your API key from: https://aistudio.google.com/app/settings
GOOGLE_AI=your-google-ai-key

# Sightengine (required for avatar moderation)
# Get your credentials from: https://dashboard.sightengine.com
# Primary keys:
SE_API_USER=your-sightengine-api-user
SE_API_SECRET=your-sightengine-api-secret
# Fallback keys (optional - used if primary hits rate limit or fails):
# SE_API_USER2=your-second-sightengine-api-user
# SE_API_SECRET2=your-second-sightengine-api-secret
# SE_API_USER3=your-third-sightengine-api-user
# SE_API_SECRET3=your-third-sightengine-api-secret
# Add more as needed (SE_API_USER4, SE_API_SECRET4, etc.)

# Github Access Tokens with PubRepo Access (optional - for 5000 API Request/hour instead of 60/hour)
GITHUB_TOKEN=your-github-access-token
